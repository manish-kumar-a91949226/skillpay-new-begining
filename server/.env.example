# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Stellar
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SKILLPAY_CONTRACT_ID=replace-after-deploy
NATIVE_XLM_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Mentor "platform" wallet used to actually sign+submit fund/release calls
# server-side (in production, prefer client-side signing via wallet extension)
PLATFORM_SIGNING_SECRET=replace-with-a-funded-testnet-secret-key

# Sentry
SENTRY_DSN=

# Gemini (optional AI reviewer bonus feature)
GEMINI_API_KEY=
